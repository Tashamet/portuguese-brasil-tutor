# Local notifier (local-notifier profile) — daily Telegram reminder.
# The CODE lives in the skill dir; the student DATA lives under
# ~/.portuguese-brasil-tutor/students/<profile>. Point cron at the code dir and
# select the student with TUTOR_PROFILE.
#
# Install with:  crontab -e   then add a line like (adjust path, profile, time):
#
# 0 19 * * * . "$HOME/.tutor_env"; cd "$HOME/.claude/skills/portuguese-brasil-tutor"; TUTOR_PROFILE=nikolai /usr/bin/python3 notifier/send_due.py >> "$HOME/.portuguese-brasil-tutor/notifier.log" 2>&1
#
# Put TELEGRAM_BOT_TOKEN in ~/.tutor_env:   export TELEGRAM_BOT_TOKEN=123:abc
# One line per student profile if you run several.
#
# Timezone: a local machine's cron already uses local time. On a machine in a
# different zone (e.g. a UTC server), make the time fire in YOUR zone by adding a
# CRON_TZ line above the job and a TZ= prefix on the command:
#   CRON_TZ=America/Sao_Paulo
#   0 19 * * * . "$HOME/.tutor_env"; cd "$HOME/.claude/skills/portuguese-brasil-tutor"; TZ=America/Sao_Paulo TUTOR_PROFILE=nikolai python3 notifier/send_due.py >> "$HOME/notifier.log" 2>&1
# (`tutor.py deploy --ssh` sets this for you from the config `timezone`.)
